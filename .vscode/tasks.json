{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Prisma DB Push",
			"type": "shell",
			"command": "npx prisma db push",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Prisma DB Push",
			"type": "shell",
			"command": "npx prisma db push",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Prisma: generate and migrate ext_expires_in",
